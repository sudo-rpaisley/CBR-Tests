{
  "plan_meta": {
    "plan_id": "tp-fortisedos-kpi-v1",
    "name": "FortisEDoS KPI Plan",
    "version": "1.0.0",
    "description": "KPI/time-series realism plan for FortisEDoS CSV datasets using column quality and Pearson correlation."
  },
  "applicability": {
    "dataset_formats": ["csv"],
    "dataset_family": ["kpi_tabular", "time_series_kpi"],
    "requires_numeric_fields": true,
    "minimum_numeric_fields": 2
  },
  "execution_policy": {
    "fail_fast": true,
    "allow_skips": false,
    "sample_mode": "full"
  },
  "metrics": [
    {
      "metric_id": "column_quality_profile",
      "label": "Column Quality Profile",
      "taxonomy_path": [
        "dataset_metrics",
        "structural_and_integrity",
        "column_quality_profile"
      ],
      "enabled": true,
      "input_requirements": {
        "candidate_fields": [
          "cpu_usage",
          "cpu_usage_sys",
          "cpu_usage_user",
          "mem_usage",
          "net_in_bytes",
          "net_out_bytes",
          "http_response_time_200",
          "http_requests_rate",
          "sockets_avg"
        ]
      },
      "calculation": {
        "method": "column_quality_profile",
        "parameters": {}
      },
      "retention": {
        "store_raw_output": true,
        "store_summary": true,
        "comparison_key": "column_quality_profile_v1"
      }
    },
    {
      "metric_id": "pearson_correlation_profile",
      "label": "Pearson Correlation Profile",
      "taxonomy_path": [
        "dataset_metrics",
        "statistical_fidelity",
        "pearson_correlation"
      ],
      "enabled": true,
      "input_requirements": {
        "candidate_fields": [
          "cpu_usage",
          "cpu_usage_sys",
          "cpu_usage_user",
          "mem_usage",
          "net_in_bytes",
          "net_out_bytes",
          "http_response_time_200",
          "http_requests_rate",
          "sockets_avg"
        ],
        "minimum_runnable_fields": 2
      },
      "calculation": {
        "method": "pairwise_pearson_matrix",
        "parameters": {
          "missing_value_policy": "drop_pairwise"
        }
      },
      "retention": {
        "store_raw_output": true,
        "store_summary": true,
        "store_column_validation": true,
        "comparison_key": "pearson_profile_v1"
      }
    }
  ]
}