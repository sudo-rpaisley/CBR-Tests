{
  "plan_meta": {
    "plan_id": "tp-dad-packet-realism-v1",
    "name": "DAD Packet Realism Plan",
    "version": "1.0.0",
    "description": "Combined packet-level realism plan for DAD-style PCAP datasets, including timestamp coherence and protocol validity."
  },
  "applicability": {
    "dataset_formats": [
      "pcap"
    ],
    "dataset_family": [
      "packet_level"
    ],
    "requires_numeric_fields": false,
    "minimum_numeric_fields": 0
  },
  "execution_policy": {
    "fail_fast": true,
    "allow_skips": false,
    "sample_mode": "full"
  },
  "metrics": [
    {
      "metric_id": "timestamp_coherence_profile",
      "label": "Timestamp Coherence Profile",
      "taxonomy_path": [
        "dataset_metrics",
        "temporal_realism",
        "timestamp_coherence"
      ],
      "enabled": true,
      "input_requirements": {},
      "calculation": {
        "method": "pcap_timestamp_scan",
        "parameters": {
          "large_gap_threshold_seconds": 1.0
        }
      },
      "retention": {
        "store_raw_output": true,
        "store_summary": true,
        "comparison_key": "timestamp_coherence_profile_v1"
      }
    },
    {
      "metric_id": "protocol_validity_profile",
      "label": "Protocol Validity Profile",
      "taxonomy_path": [
        "dataset_heuristics",
        "protocol_and_network_realism",
        "address_validity",
        "valid_ip_address"
      ],
      "enabled": true,
      "input_requirements": {},
      "calculation": {
        "method": "pcap_protocol_scan",
        "parameters": {}
      },
      "retention": {
        "store_raw_output": true,
        "store_summary": true,
        "comparison_key": "protocol_validity_profile_v1"
      }
    }
  ],
  "plan_taxonomy": {
    "dataset_metrics": {
      "temporal_realism": {
        "timestamp_coherence": {
          "_metrics": [
            {
              "metric_id": "timestamp_coherence_profile",
              "enabled": true
            }
          ]
        }
      }
    },
    "dataset_heuristics": {
      "protocol_and_network_realism": {
        "address_validity": {
          "valid_ip_address": {
            "_metrics": [
              {
                "metric_id": "protocol_validity_profile",
                "enabled": true
              }
            ]
          }
        }
      }
    }
  }
}